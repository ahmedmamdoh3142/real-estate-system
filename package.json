{
  "name": "real-estate-backend",
  "version": "1.0.0",
  "description": "Backend for Real Estate Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test-db": "node test-db-simple.js",
    "enable-browser": "powershell -Command \"Set-Service -Name 'SQLBrowser' -StartupType Automatic; Start-Service -Name 'SQLBrowser'\"",
    "check-sql": "powershell -Command \"Get-Service -Name 'MSSQL$ATTENDANCE', 'SQLBrowser' | Select-Object Name, Status, StartType\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "msnodesqlv8": "^5.1.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
